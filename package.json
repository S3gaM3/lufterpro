{
  "name": "newlufter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:admin": "npm run dev -w apps/admin",
    "dev:api": "npm run dev -w apps/api",
    "build": "tsc -b && vite build",
    "build:admin": "npm run build -w apps/admin",
    "build:api": "npm run build -w apps/api",
    "lint": "eslint .",
    "lint:admin": "npm run lint -w apps/admin",
    "lint:api": "npm run lint -w apps/api",
    "ci:storefront": "npm run lint && npm run build",
    "ci:admin": "npm run lint:admin && npm run build:admin",
    "ci:api": "npm run lint:api && npm run prisma:generate -w apps/api && npm run build:api",
    "ci:all": "npm run ci:storefront && npm run ci:admin && npm run ci:api",
    "preview": "vite preview",
    "images:download": "node scripts/download-images.mjs",
    "images:convert": "node scripts/convert-to-webp.mjs"
  },
  "dependencies": {
    "@fontsource-variable/syne": "^5.2.7",
    "@fontsource/montserrat": "^5.2.8",
    "framer-motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/estree": "^1.0.8",
    "@types/node": "^22.9.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "^8.4.47",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.10"
  },
  "description": "newlufter storefront + CMS monorepo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/S3gaM3/newlufter.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/S3gaM3/newlufter/issues"
  },
  "homepage": "https://github.com/S3gaM3/newlufter#readme"
}
